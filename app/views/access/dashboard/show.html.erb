<div class="min-h-screen bg-dark-bg">
  <div class="min-h-screen">
    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 py-8">
      <!-- Welcome Section -->
      <div class="mb-8">
        <h2 class="text-4xl md:text-5xl font-black text-white mb-2">
          Bem-vindo, <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-neon-purple"><%= @user.display_name_with_squad_tag.split('#').first %></span>!
        </h2>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <!-- Guild -->
        <div class="bg-dark-card border border-neon-cyan/30 rounded-lg p-6 hover:border-neon-cyan hover:shadow-neon-cyan transition-all duration-300">
          <div class="flex items-center justify-between mb-3">
            <span class="text-neon-cyan/70 text-sm font-mono uppercase">Guilda</span>
            <span class="text-3xl">🏰</span>
          </div>
          <p class="text-white text-xl font-bold truncate"><%= @guild.name %></p>
        </div>

        <!-- XP -->
        <div class="bg-dark-card border border-neon-purple/30 rounded-lg p-6 hover:border-neon-purple hover:shadow-neon-purple transition-all duration-300">
          <div class="flex items-center justify-between mb-3">
            <span class="text-neon-purple/70 text-sm font-mono uppercase">XP</span>
            <span class="text-3xl">⚡</span>
          </div>
          <p class="text-white text-2xl font-bold"><%= @user.xp_points %></p>
          <p class="text-gray-500 text-xs font-mono">PONTOS XP</p>
        </div>

        <!-- Currency -->
        <div class="bg-dark-card border border-neon-magenta/30 rounded-lg p-6 hover:border-neon-magenta hover:shadow-neon-magenta transition-all duration-300">
          <div class="flex items-center justify-between mb-3">
            <span class="text-neon-magenta/70 text-sm font-mono uppercase">Moedas</span>
            <span class="text-3xl">💎</span>
          </div>
          <p class="text-white text-2xl font-bold"><%= @user.currency_balance %></p>
          <p class="text-gray-500 text-xs font-mono">MOEDAS</p>
        </div>

        <!-- Level -->
        <div class="bg-dark-card border border-neon-green/30 rounded-lg p-6 hover:border-neon-green hover:shadow-neon-green transition-all duration-300">
          <div class="flex items-center justify-between mb-3">
            <span class="text-neon-green/70 text-sm font-mono uppercase">Nível</span>
            <span class="text-3xl">🎖️</span>
          </div>
          <p class="text-white text-2xl font-bold"><%= @user.level %></p>
          <p class="text-gray-500 text-xs font-mono">NÍVEL ATUAL</p>
        </div>
      </div>

      <!-- Modules Grid -->
      <div class="mb-8">
        <h3 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
          <span class="text-neon-cyan">▶</span> Módulos
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Events Module -->
          <%= link_to events_path, class: "group bg-dark-card border border-neon-cyan/20 rounded-lg p-6 hover:border-neon-cyan hover:shadow-neon-cyan transition-all duration-300 block" do %>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-5xl group-hover:animate-pulse">🎯</span>
                <div>
                  <h4 class="text-neon-cyan font-bold text-lg uppercase">Eventos</h4>
                  <p class="text-gray-400 text-sm">Eventos da guilda</p>
                </div>
              </div>
            </div>
            <p class="text-gray-400 text-sm mb-4">
              Gerencie e participe de eventos da guild. Acompanhe sua participação e pontuação.
            </p>
          <% end %>

          <!-- Missions Module -->
          <%= link_to missions_path, class: "group bg-dark-card border border-neon-purple/20 rounded-lg p-6 hover:border-neon-purple hover:shadow-neon-purple transition-all duration-300 block" do %>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-5xl group-hover:animate-pulse">📋</span>
                <div>
                  <h4 class="text-neon-purple font-bold text-lg uppercase">Missões</h4>
                  <p class="text-gray-400 text-sm">Missões e recompensas</p>
                </div>
              </div>
            </div>
            <p class="text-gray-400 text-sm mb-4">
              Complete missões para ganhar XP e moedas. Acompanhe seu progresso em tempo real.
            </p>
          <% end %>

          <!-- Achievements Module -->
          <%= link_to achievements_path, class: "group bg-dark-card border border-neon-magenta/20 rounded-lg p-6 hover:border-neon-magenta hover:shadow-neon-magenta transition-all duration-300 block" do %>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-5xl group-hover:animate-pulse">🏆</span>
                <div>
                  <h4 class="text-neon-magenta font-bold text-lg uppercase">Conquistas</h4>
                  <p class="text-gray-400 text-sm">Conquistas desbloqueadas</p>
                </div>
              </div>
            </div>
            <p class="text-gray-400 text-sm mb-4">
              Desbloqueie conquistas especiais e mostre suas habilidades para a guild.
            </p>
          <% end %>

          <!-- Certificates Module -->
          <%= link_to certificates_path, class: "group bg-dark-card border border-yellow-400/20 rounded-lg p-6 hover:border-yellow-400 hover:shadow-lg transition-all duration-300 block" do %>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-5xl group-hover:animate-pulse">📜</span>
                <div>
                  <h4 class="text-yellow-400 font-bold text-lg uppercase">Certificados</h4>
                  <p class="text-gray-400 text-sm">Certificações da guilda</p>
                </div>
              </div>
            </div>
            <p class="text-gray-400 text-sm mb-4">
              Obtenha certificados oficiais da guild e valide suas competências.
            </p>
          <% end %>

          <!-- Profile Module -->
          <%= link_to profile_path, class: "group bg-dark-card border border-neon-blue/20 rounded-lg p-6 hover:border-neon-blue hover:shadow-lg transition-all duration-300 block" do %>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-5xl group-hover:animate-pulse">👤</span>
                <div>
                  <h4 class="text-neon-blue font-bold text-lg uppercase">Perfil</h4>
                  <p class="text-gray-400 text-sm">Dados e progresso</p>
                </div>
              </div>
            </div>
            <p class="text-gray-400 text-sm mb-4">
              Visualize e edite suas informações de perfil, roles e estatísticas pessoais.
            </p>
          <% end %>

          <!-- Rankings Module -->
          <%= link_to rankings_path, class: "group bg-dark-card border border-neon-cyan/20 rounded-lg p-6 hover:border-neon-cyan hover:shadow-neon-cyan transition-all duration-300 block" do %>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-5xl group-hover:animate-pulse">📊</span>
                <div>
                  <h4 class="text-neon-cyan font-bold text-lg uppercase">Rankings</h4>
                  <p class="text-gray-400 text-sm">Classificações</p>
                </div>
              </div>
            </div>
            <p class="text-gray-400 text-sm mb-4">
              Compare progresso de membros e squads por XP, nível, poder e participação.
            </p>
          <% end %>

          <!-- Squads Module -->
          <%= link_to squads_path, class: "group bg-dark-card border border-neon-green/20 rounded-lg p-6 hover:border-neon-green hover:shadow-neon-green transition-all duration-300 block" do %>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-5xl group-hover:animate-pulse">🛡️</span>
                <div>
                  <h4 class="text-neon-green font-bold text-lg uppercase">Squads</h4>
                  <p class="text-gray-400 text-sm">Squads e convites</p>
                </div>
              </div>
            </div>
            <p class="text-gray-400 text-sm mb-4">
              Gerencie squads, liderança, convites e revisão de alterações de perfil.
            </p>
          <% end %>

          <!-- Store Module -->
          <%= link_to store_path, class: "group bg-dark-card border border-neon-magenta/20 rounded-lg p-6 hover:border-neon-magenta hover:shadow-neon-magenta transition-all duration-300 block" do %>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-5xl group-hover:animate-pulse">💎</span>
                <div>
                  <h4 class="text-neon-magenta font-bold text-lg uppercase">Loja</h4>
                  <p class="text-gray-400 text-sm">Loja e pedidos</p>
                </div>
              </div>
            </div>
            <p class="text-gray-400 text-sm mb-4">
              Troque moedas por itens e acompanhe o atendimento manual dos seus pedidos.
            </p>
          <% end %>

          <!-- Management Area -->
          <% if @user.manage_area_access? %>
            <%= link_to manage_root_path, class: "group bg-dark-card border border-neon-green/20 rounded-lg p-6 hover:border-neon-green hover:shadow-lg transition-all duration-300 block" do %>
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                  <span class="text-5xl group-hover:animate-pulse">⚙️</span>
                  <div>
                    <h4 class="text-neon-green font-bold text-lg uppercase">Gestão</h4>
                    <p class="text-gray-400 text-sm">Operação da guilda</p>
                  </div>
                </div>
              </div>
              <p class="text-gray-400 text-sm mb-4">
                Gerencie os módulos permitidos para seu cargo diretamente no sistema da guild.
              </p>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="mb-8">
        <h3 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
          <span class="text-neon-magenta">▶</span> Ações rápidas
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <%= button_to logout_path, method: :delete, class: "group relative overflow-hidden bg-gradient-to-r from-gray-600 to-gray-700 p-[2px] rounded-lg hover:shadow-lg transition-all duration-300", data: { turbo: false } do %>
            <div class="bg-dark-bg rounded-lg p-4 flex items-center justify-center gap-3">
              <span class="text-3xl group-hover:animate-pulse">🚪</span>
              <span class="text-gray-300 font-bold">Sair</span>
            </div>
          <% end %>

          <% if @guild.discord_guild_id.present? %>
            <a href="https://discord.com/channels/<%= @guild.discord_guild_id %>" 
               target="_blank"
               class="group relative overflow-hidden bg-gradient-to-r from-neon-cyan to-neon-blue p-[2px] rounded-lg hover:shadow-neon-cyan transition-all duration-300">
              <div class="bg-dark-bg rounded-lg p-4 flex items-center justify-center gap-3">
                <span class="text-3xl group-hover:animate-pulse">💬</span>
                <span class="text-neon-cyan font-bold uppercase tracking-wide">Discord</span>
              </div>
            </a>
          <% end %>

          <%= link_to root_path, class: "group relative overflow-hidden bg-gradient-to-r from-neon-purple to-neon-magenta p-[2px] rounded-lg hover:shadow-neon-purple transition-all duration-300" do %>
            <div class="bg-dark-bg rounded-lg p-4 flex items-center justify-center gap-3">
              <span class="text-3xl group-hover:animate-pulse">🏠</span>
              <span class="text-neon-purple font-bold uppercase tracking-wide">Início</span>
            </div>
          <% end %>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-800 mt-12">
      <div class="max-w-7xl mx-auto px-4 py-6">
        <div class="text-center">
          <p class="text-gray-500 text-sm">
            © 2026 Guild Manager
          </p>
        </div>
      </div>
    </footer>
  </div>
</div>
