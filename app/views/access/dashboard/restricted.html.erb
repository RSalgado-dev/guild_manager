<div class="min-h-screen bg-dark-bg">
  <div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="max-w-3xl w-full">
      <div class="text-center mb-8">
        <div class="inline-block mb-6">
          <div class="mx-auto flex items-center justify-center h-24 w-24 rounded-full border border-neon-magenta bg-dark-card mb-4">
            <svg class="h-16 w-16 text-neon-magenta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
        </div>

        <h1 class="text-4xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-neon-magenta via-neon-purple to-neon-cyan mb-4">
          Acesso restrito
        </h1>

        <p class="text-xl text-gray-300 mb-2">
          Permissões insuficientes para acessar os recursos internos
        </p>
        
      </div>

      <!-- Warning Box -->
      <div class="bg-dark-card border-l-4 border-yellow-400 rounded-lg p-6 mb-8 backdrop-blur-sm">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0">
            <svg class="h-8 w-8 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-yellow-400 font-bold text-lg mb-3">
              Acesso exclusivo para membros
            </h3>
            <div class="text-gray-300 leading-relaxed">
              <p class="mb-2">
                Para acessar os recursos internos, você precisa ter o cargo de 
                <span class="text-neon-cyan font-bold font-mono">"<%= @guild.required_discord_role_name || 'Membro' %>"</span> 
                no servidor Discord da guilda 
                <span class="text-neon-purple font-bold">"<%= @guild.name %>"</span>.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Instructions -->
      <div class="bg-dark-card border border-neon-cyan/30 rounded-lg p-6 mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-4xl">📋</span>
          <h3 class="text-neon-cyan font-bold text-xl">Como obter acesso</h3>
        </div>
        <ol class="space-y-3 text-gray-300">
          <li class="flex items-start gap-3">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-neon-cyan/20 border border-neon-cyan flex items-center justify-center text-neon-cyan font-bold font-mono text-sm">1</span>
            <span class="pt-1">Certifique-se de estar no servidor Discord da guilda</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-neon-purple/20 border border-neon-purple flex items-center justify-center text-neon-purple font-bold font-mono text-sm">2</span>
            <span class="pt-1">Entre em contato com um administrador do servidor</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-neon-magenta/20 border border-neon-magenta flex items-center justify-center text-neon-magenta font-bold font-mono text-sm">3</span>
            <span class="pt-1">Solicite o cargo necessário para acesso ao site</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-neon-green/20 border border-neon-green flex items-center justify-center text-neon-green font-bold font-mono text-sm">4</span>
            <span class="pt-1">Após receber o cargo, faça logout e login novamente</span>
          </li>
        </ol>
      </div>

      <!-- Action Buttons -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <% if @guild.discord_guild_id.present? %>
          <a href="https://discord.com/channels/<%= @guild.discord_guild_id %>" 
             target="_blank"
             class="group relative overflow-hidden bg-gradient-to-r from-neon-cyan to-neon-blue p-[2px] rounded-lg hover:shadow-neon-cyan transition-all duration-300 transform hover:scale-105">
            <div class="bg-dark-card rounded-lg p-4 h-full flex items-center justify-center gap-3">
              <svg class="w-8 h-8 text-neon-cyan group-hover:animate-pulse" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
              </svg>
              <div class="text-left">
              <p class="text-neon-cyan font-bold">Ir para Discord</p>
                <p class="text-gray-400 text-sm">Servidor da guilda</p>
              </div>
            </div>
          </a>
        <% end %>

        <%= button_to logout_path, method: :delete, class: "group relative overflow-hidden bg-gradient-to-r from-gray-600 to-gray-700 p-[2px] rounded-lg hover:shadow-lg transition-all duration-300 transform hover:scale-105", data: { turbo: false } do %>
          <div class="bg-dark-card rounded-lg p-4 h-full flex items-center justify-center gap-3">
            <span class="text-4xl group-hover:animate-pulse">🚪</span>
            <div class="text-left">
              <p class="text-gray-300 font-bold">Sair</p>
              <p class="text-gray-500 text-sm">Desconectar</p>
            </div>
          </div>
        <% end %>

        <%= link_to root_path, class: "group relative overflow-hidden bg-gradient-to-r from-neon-purple to-neon-magenta p-[2px] rounded-lg hover:shadow-neon-purple transition-all duration-300 transform hover:scale-105" do %>
          <div class="bg-dark-card rounded-lg p-4 h-full flex items-center justify-center gap-3">
            <span class="text-4xl group-hover:animate-pulse">🏠</span>
            <div class="text-left">
              <p class="text-neon-purple font-bold">Voltar ao início</p>
              <p class="text-gray-400 text-sm">Página principal</p>
            </div>
          </div>
        <% end %>
      </div>

      <!-- User Info Footer -->
      <div class="text-center pt-8 border-t border-gray-800">
        <p class="text-gray-300">
          Você está logado como 
          <span class="text-neon-cyan font-bold"><%= current_user.discord_username %></span>
        </p>
      </div>
    </div>
  </div>
</div>
