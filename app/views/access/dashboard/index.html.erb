<div class="min-h-screen bg-dark-bg">
  <div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="max-w-7xl w-full">
      <% if logged_in? %>
        <!-- Usuário Logado - Dashboard Mode -->
        <div class="space-y-8">
          <!-- Header com avatar -->
          <div class="text-center space-y-6">
            <div class="inline-block relative">
              <% if current_user.discord_avatar_url.present? %>
                <%= image_tag current_user.discord_avatar_url, class: "w-32 h-32 rounded-full border-4 border-neon-cyan shadow-neon-cyan mx-auto" %>
              <% else %>
                <div class="w-32 h-32 rounded-full border-4 border-neon-cyan shadow-neon-cyan mx-auto bg-dark-card flex items-center justify-center">
                  <span class="text-6xl">👤</span>
                </div>
              <% end %>
              <div class="absolute -bottom-2 -right-2 bg-neon-green rounded-full px-3 py-1 border-2 border-dark-bg shadow-neon-green">
                <span class="text-xs font-bold text-dark-bg">Ativo</span>
              </div>
            </div>
            
            <div>
              <h1 class="text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan via-neon-purple to-neon-magenta mb-2 animate-glow">
                <%= current_user.discord_username %>
              </h1>
              <p class="text-neon-cyan text-lg">Acesso autorizado</p>
            </div>
          </div>

          <!-- Stats Grid -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
            <div class="bg-dark-card border border-neon-cyan/30 rounded-lg p-6 hover:border-neon-cyan hover:shadow-neon-cyan transition-all duration-300">
              <div class="flex items-center justify-between mb-2">
                <span class="text-neon-cyan/70 text-sm font-mono uppercase">Guilda</span>
                <span class="text-2xl">🏰</span>
              </div>
              <p class="text-white text-2xl font-bold truncate"><%= current_user.guild&.name || 'N/A' %></p>
            </div>
            
            <div class="bg-dark-card border border-neon-purple/30 rounded-lg p-6 hover:border-neon-purple hover:shadow-neon-purple transition-all duration-300">
              <div class="flex items-center justify-between mb-2">
                <span class="text-neon-purple/70 text-sm font-mono uppercase">XP</span>
                <span class="text-2xl">⚡</span>
              </div>
              <p class="text-white text-2xl font-bold"><%= current_user.xp_points %> XP</p>
            </div>
            
            <div class="bg-dark-card border border-neon-magenta/30 rounded-lg p-6 hover:border-neon-magenta hover:shadow-neon-magenta transition-all duration-300">
              <div class="flex items-center justify-between mb-2">
                <span class="text-neon-magenta/70 text-sm font-mono uppercase">Moedas</span>
                <span class="text-2xl">💎</span>
              </div>
              <p class="text-white text-2xl font-bold"><%= current_user.currency_balance %></p>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
            <%= link_to dashboard_path, class: "group relative overflow-hidden bg-gradient-to-r from-neon-cyan to-neon-blue p-[2px] rounded-lg hover:shadow-neon-cyan transition-all duration-300 transform hover:scale-105" do %>
              <div class="bg-dark-bg rounded-lg p-6 h-full flex flex-col items-center justify-center gap-3">
                <span class="text-5xl group-hover:animate-pulse">🎯</span>
                <span class="text-neon-cyan font-bold text-xl">Painel</span>
                <span class="text-gray-400 text-sm font-mono">Acessar sistema</span>
              </div>
            <% end %>

            <% if current_user.manage_area_access? %>
              <%= link_to manage_root_path, class: "group relative overflow-hidden bg-gradient-to-r from-neon-purple to-neon-magenta p-[2px] rounded-lg hover:shadow-neon-purple transition-all duration-300 transform hover:scale-105" do %>
                <div class="bg-dark-bg rounded-lg p-6 h-full flex flex-col items-center justify-center gap-3">
                  <span class="text-5xl group-hover:animate-pulse">⚙️</span>
                  <span class="text-neon-purple font-bold text-xl uppercase tracking-wide">Gestão</span>
                  <span class="text-gray-400 text-sm font-mono">Operação da guild</span>
                </div>
              <% end %>
            <% end %>

            <%= button_to logout_path, method: :delete, class: "group relative overflow-hidden bg-gradient-to-r from-gray-600 to-gray-700 p-[2px] rounded-lg hover:shadow-lg transition-all duration-300 transform hover:scale-105", data: { turbo: false } do %>
              <div class="bg-dark-bg rounded-lg p-6 h-full flex flex-col items-center justify-center gap-3">
                <span class="text-5xl group-hover:animate-pulse">🚪</span>
                <span class="text-gray-300 font-bold text-xl">Sair</span>
                <span class="text-gray-500 text-sm font-mono">Desconectar</span>
              </div>
            <% end %>
          </div>
        </div>

      <% else %>
        <!-- Usuário Deslogado - Landing Page -->
        <div class="space-y-12">
          <!-- Hero Section -->
          <div class="text-center space-y-6 max-w-4xl mx-auto">
            <div class="inline-block mb-4">
              <div class="text-8xl mb-4 drop-shadow-[0_0_25px_rgba(0,255,255,0.5)]">🏰</div>
            </div>
            
            <h1 class="text-7xl md:text-8xl font-black text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan via-neon-purple to-neon-magenta leading-tight animate-glow">
              Guild Manager
            </h1>
            
            <div class="space-y-2">
              <p class="text-2xl md:text-3xl text-white font-bold tracking-wide">
                Gerenciamento de guildas
              </p>
              <p class="text-neon-cyan text-lg">
                Integração com Discord
              </p>
            </div>
          </div>

          <!-- Login Section -->
          <div class="max-w-md mx-auto space-y-4">
            <div class="text-center mb-6">
              <p class="text-white text-xl font-bold mb-2">Entrar</p>
              <p class="text-gray-400 text-sm">Autentique-se via Discord</p>
            </div>

            <%= link_to discord_login_path, class: "group relative overflow-hidden bg-gradient-to-r from-neon-cyan to-neon-blue p-[3px] rounded-lg hover:shadow-neon-cyan transition-all duration-300 transform hover:scale-105 block", data: { turbo: false } do %>
              <div class="bg-dark-card rounded-lg p-6 flex items-center justify-center gap-4">
                <svg class="w-10 h-10 text-neon-cyan group-hover:animate-pulse" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                </svg>
                <div class="text-left">
                  <p class="text-white font-bold text-xl">Conectar Discord</p>
                  <p class="text-neon-cyan/70 text-sm">Autenticação OAuth2</p>
                </div>
              </div>
            <% end %>

            <% if Rails.env.development? %>
              <%= link_to dev_login_path, class: "group relative overflow-hidden bg-gradient-to-r from-gray-600 to-gray-700 p-[2px] rounded-lg hover:shadow-lg transition-all duration-300 block" do %>
                <div class="bg-dark-card rounded-lg p-4 flex items-center justify-center gap-3">
                  <span class="text-2xl group-hover:animate-pulse">🛠️</span>
                  <div class="text-left">
                    <p class="text-gray-300 font-bold">Modo dev</p>
                    <p class="text-gray-500 text-xs">Apenas desenvolvimento</p>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>

          <!-- Features Grid -->
          <div class="max-w-6xl mx-auto">
            <div class="text-center mb-8">
              <p class="text-white text-2xl font-bold mb-2">Recursos</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
              <div class="bg-dark-card border border-neon-cyan/20 rounded-lg p-6 hover:border-neon-cyan hover:shadow-neon-cyan transition-all duration-300">
                <div class="text-5xl mb-4 text-center">🎯</div>
                <h3 class="text-neon-cyan font-bold text-lg text-center mb-2">Eventos</h3>
                <p class="text-gray-400 text-sm text-center">Gerenciamento de eventos</p>
              </div>

              <div class="bg-dark-card border border-neon-purple/20 rounded-lg p-6 hover:border-neon-purple hover:shadow-neon-purple transition-all duration-300">
                <div class="text-5xl mb-4 text-center">📋</div>
                <h3 class="text-neon-purple font-bold text-lg text-center mb-2">Missões</h3>
                <p class="text-gray-400 text-sm text-center">Sistema de missões</p>
              </div>

              <div class="bg-dark-card border border-neon-magenta/20 rounded-lg p-6 hover:border-neon-magenta hover:shadow-neon-magenta transition-all duration-300">
                <div class="text-5xl mb-4 text-center">🏆</div>
                <h3 class="text-neon-magenta font-bold text-lg text-center mb-2">Conquistas</h3>
                <p class="text-gray-400 text-sm text-center">Acompanhamento de conquistas</p>
              </div>

              <div class="bg-dark-card border border-neon-green/20 rounded-lg p-6 hover:border-neon-green hover:shadow-neon-green transition-all duration-300">
                <div class="text-5xl mb-4 text-center">📜</div>
                <h3 class="text-neon-green font-bold text-lg text-center mb-2">Certificados</h3>
                <p class="text-gray-400 text-sm text-center">Certificações da guilda</p>
              </div>
            </div>
          </div>

          <!-- Info Box -->
          <div class="max-w-2xl mx-auto">
            <div class="bg-dark-card border border-neon-blue/30 rounded-lg p-6">
              <div class="flex items-start gap-4">
                <div class="text-4xl">💡</div>
                <div>
                  <p class="text-neon-blue font-bold text-lg mb-2">Sobre o sistema</p>
                  <p class="text-gray-300 leading-relaxed">
                    Plataforma completa de gerenciamento de guildas integrada ao Discord. 
                    Controle de acesso baseado em servidores e cargos, sistema de progressão com XP, 
                    moedas, conquistas e certificações.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Footer -->
      <div class="text-center mt-16 pt-8 border-t border-gray-800">
        <p class="text-gray-600 text-xs">
          © 2026 Guild Manager
        </p>
      </div>
    </div>
  </div>
</div>
