<div class="min-h-screen bg-dark-bg">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <p class="text-neon-cyan/70 font-mono text-xs uppercase">Store</p>
        <h1 class="text-4xl font-black text-white">Loja da Guild</h1>
        <p class="text-gray-400 mt-2">Use suas moedas para resgatar itens e benefícios manuais.</p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <div class="bg-dark-card border border-neon-magenta/30 rounded-lg px-4 py-3">
          <p class="text-gray-500 text-xs font-mono uppercase">Saldo</p>
          <p class="text-white text-2xl font-bold"><%= current_user.currency_balance %> moedas</p>
        </div>
        <%= link_to "Meus pedidos", store_orders_path, class: "inline-flex items-center justify-center border border-neon-cyan/30 bg-dark-card text-neon-cyan font-bold rounded px-4 py-3 hover:border-neon-cyan transition-colors" %>
        <%= link_to "Dashboard", dashboard_path, class: "inline-flex items-center justify-center border border-neon-cyan/30 text-neon-cyan rounded px-4 py-3 hover:border-neon-cyan transition-colors" %>
      </div>
    </div>

    <% if @items.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        <% @items.each do |item| %>
          <% can_purchase = current_user.currency_balance >= item.price && item.available_for_purchase? %>
          <div class="bg-dark-card border border-neon-cyan/20 rounded-lg p-6">
            <div class="flex items-start justify-between gap-3 mb-4">
              <div>
                <p class="text-neon-cyan/70 text-xs font-mono uppercase"><%= item.category_label %></p>
                <h2 class="text-white text-xl font-bold mt-1"><%= item.name %></h2>
              </div>
              <span class="text-neon-magenta font-black text-lg"><%= item.price %></span>
            </div>

            <p class="text-gray-400 text-sm min-h-16"><%= item.description.presence || "Sem descrição." %></p>

            <div class="mt-5 flex items-center justify-between text-xs font-mono">
              <span class="text-gray-500">Estoque</span>
              <span class="text-neon-green">
                <%= item.unlimited_stock? ? "ILIMITADO" : item.stock_quantity %>
              </span>
            </div>

            <div class="mt-5">
              <% if can_purchase %>
                <%= button_to (item.price.zero? ? "Resgatar grátis" : "Comprar por #{item.price} moedas"),
                              store_orders_path(store_item_id: item.id),
                              method: :post,
                              data: {
                                turbo_confirm: item.price.zero? ? "Confirmar resgate gratuito de #{item.name}?" : "Confirmar compra de #{item.name} por #{item.price} moedas?"
                              },
                              class: "w-full rounded border border-neon-green/40 bg-neon-green/20 px-4 py-3 font-bold text-neon-green hover:border-neon-green hover:bg-neon-green/30 transition-colors" %>
              <% else %>
                <%= button_tag (item.available_for_purchase? ? "Saldo insuficiente" : "Indisponível"),
                               type: "button",
                               disabled: true,
                               class: "w-full rounded border border-gray-700 bg-gray-800 px-4 py-3 font-bold text-gray-400 cursor-not-allowed" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-dark-card border border-gray-800 rounded-lg p-8 text-center mb-10">
        <p class="text-gray-400">Nenhum item disponível na loja no momento.</p>
      </div>
    <% end %>

    <div class="bg-dark-card border border-neon-purple/20 rounded-lg p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-white text-2xl font-bold">Pedidos recentes</h2>
        <%= link_to "Ver todos", store_orders_path, class: "text-neon-cyan hover:underline" %>
      </div>

      <% if @recent_orders.any? %>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead class="text-gray-500 text-xs font-mono uppercase border-b border-gray-800">
              <tr>
                <th class="py-3">Pedido</th>
                <th class="py-3">Item</th>
                <th class="py-3">Preço</th>
                <th class="py-3">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% @recent_orders.each do |order| %>
                <tr>
                  <td class="py-3 text-gray-300">#<%= order.id %></td>
                  <td class="py-3 text-white"><%= order.store_item.name %></td>
                  <td class="py-3 text-neon-magenta"><%= order.price_paid %></td>
                  <td class="py-3 text-neon-cyan"><%= order.status %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-gray-400">Você ainda não criou pedidos.</p>
      <% end %>
    </div>
  </div>
</div>
