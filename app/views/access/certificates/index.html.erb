<div class="min-h-screen bg-dark-bg">
  <div class="max-w-7xl mx-auto px-4 py-8 space-y-8">
    <header class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="text-neon-blue font-mono text-xs">[ CERTIFICATE_CATALOG ]</p>
        <h1 class="text-3xl font-black text-white mt-2">Certificados</h1>
        <p class="text-gray-400 mt-2">Certificados oficiais e competências reconhecidas pela guilda.</p>
      </div>
      <%= link_to dashboard_path, class: "px-4 py-2 bg-dark-card border border-gray-700 rounded-lg text-gray-300 font-mono text-sm" do %>
        ← Dashboard
      <% end %>
    </header>

    <% if @certificates.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <% @certificates.each do |certificate| %>
          <% user_certificate = @user_certificates[certificate.id] %>
          <% granted = user_certificate&.active_certificate? %>
          <%= link_to certificate_path(certificate), class: "block bg-dark-card border #{granted ? 'border-neon-blue/60' : 'border-gray-800'} rounded-lg p-5 hover:border-neon-blue transition-colors" do %>
            <div class="flex items-start justify-between gap-4">
              <div class="flex items-start gap-3">
                <span class="text-4xl"><%= certificate.icon_url.presence || "📜" %></span>
                <div>
                  <h2 class="text-white font-bold text-lg"><%= certificate.name %></h2>
                  <p class="text-gray-500 text-xs font-mono mt-1"><%= certificate.category.presence || "geral" %></p>
                </div>
              </div>
              <span class="px-2 py-1 rounded border text-xs font-mono <%= granted ? 'border-neon-blue text-neon-blue bg-neon-blue/10' : 'border-gray-700 text-gray-500 bg-dark-bg' %>">
                <%= granted ? "obtido" : "pendente" %>
              </span>
            </div>

            <% if certificate.description.present? %>
              <p class="text-gray-400 text-sm mt-4"><%= certificate.description %></p>
            <% end %>

            <% if certificate.role.present? %>
              <div class="mt-5">
                <span class="px-2 py-1 bg-neon-purple/10 border border-neon-purple/30 rounded text-neon-purple text-xs font-mono"><%= certificate.role.name %></span>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-dark-card border border-dashed border-gray-700 rounded-lg p-10 text-center">
        <p class="text-gray-400">Nenhum certificado ativo no momento.</p>
      </div>
    <% end %>
  </div>
</div>
