<div class="min-h-screen py-8 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-4xl font-bold bg-gradient-to-r from-neon-cyan via-neon-purple to-neon-magenta bg-clip-text text-transparent">
          ⚙️ Editar Personagem
        </h1>
        <p class="text-gray-400 mt-2">Atualize os dados conforme o modelo da guilda</p>
      </div>
      <%= link_to "← Voltar ao Perfil", profile_path, class: "px-4 py-2 bg-dark-surface border border-neon-cyan/30 rounded-lg text-neon-cyan hover:bg-neon-cyan/10" %>
    </div>

    <div class="card-neon p-8">
      <% nickname_field = @template_fields.find { |field| field["key"] == "nickname" } %>
      <% level_field = @template_fields.find { |field| field["key"] == "level" } %>
      <% power_field = @template_fields.find { |field| field["key"] == "power" } %>
      <% custom_fields = @template_fields.reject { |field| field["system"] } %>

      <%= form_with model: @character, url: character_path(@character), method: :patch, local: true, class: "space-y-6" do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="md:col-span-2">
            <%= f.label :nickname, (nickname_field&.dig("label") || "Nickname"), class: "block text-sm font-medium text-gray-300 mb-2" %>
            <%= f.text_field :nickname,
                required: nickname_field&.dig("required") != false,
                placeholder: nickname_field&.dig("placeholder"),
                maxlength: 50,
                class: "w-full px-4 py-3 bg-dark-bg border border-neon-cyan/30 rounded-lg text-white" %>
          </div>

          <div>
            <%= f.label :level, (level_field&.dig("label") || "Nível"), class: "block text-sm font-medium text-gray-300 mb-2" %>
            <%= f.number_field :level,
                required: level_field&.dig("required") != false,
                min: 1,
                max: 999,
                class: "w-full px-4 py-3 bg-dark-bg border border-neon-purple/30 rounded-lg text-white" %>
          </div>

          <div>
            <%= f.label :power, (power_field&.dig("label") || "Poder"), class: "block text-sm font-medium text-gray-300 mb-2" %>
            <%= f.number_field :power,
                required: power_field&.dig("required") != false,
                min: 0,
                class: "w-full px-4 py-3 bg-dark-bg border border-neon-magenta/30 rounded-lg text-white" %>
          </div>
        </div>

        <% if custom_fields.any? %>
          <div class="pt-6 border-t border-gray-700">
            <h3 class="text-lg font-semibold text-neon-cyan mb-4">Campos do Modelo da Guilda</h3>
            <div class="space-y-4">
              <% custom_fields.each do |field| %>
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-2"><%= field["label"] %></label>
                  <% value = @character.character_data&.[](field["key"]) %>
                  <% if field["field_type"] == "integer" %>
                    <%= number_field_tag "game_character[character_data][#{field['key']}]", value, required: field["required"], class: "w-full px-4 py-3 bg-dark-bg border border-neon-cyan/30 rounded-lg text-white" %>
                  <% elsif field["field_type"] == "decimal" %>
                    <%= number_field_tag "game_character[character_data][#{field['key']}]", value, step: "any", required: field["required"], class: "w-full px-4 py-3 bg-dark-bg border border-neon-cyan/30 rounded-lg text-white" %>
                  <% elsif field["field_type"] == "boolean" %>
                    <%= select_tag "game_character[character_data][#{field['key']}]", options_for_select([["Selecione", ""], ["Sim", "true"], ["Não", "false"]], value.to_s), required: field["required"], class: "w-full px-4 py-3 bg-dark-bg border border-neon-cyan/30 rounded-lg text-white" %>
                  <% else %>
                    <%= text_field_tag "game_character[character_data][#{field['key']}]", value, required: field["required"], placeholder: field["placeholder"], class: "w-full px-4 py-3 bg-dark-bg border border-neon-cyan/30 rounded-lg text-white" %>
                  <% end %>
                  <% if field["help_text"].present? %>
                    <p class="text-xs text-gray-500 mt-1"><%= field["help_text"] %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <div class="pt-6 border-t border-gray-700">
          <%= f.label :status_screenshot, "Atualizar Print da Tela de Status", class: "block text-sm font-medium text-gray-300 mb-2" %>
          <%= f.file_field :status_screenshot, accept: "image/jpeg,image/jpg,image/png,image/webp", class: "w-full px-4 py-3 bg-dark-bg border border-neon-cyan/30 rounded-lg text-white" %>
        </div>

        <div class="pt-2">
          <label class="inline-flex items-center gap-2 text-gray-300">
            <%= f.check_box :is_primary, class: "rounded border-neon-cyan/30 bg-dark-bg text-neon-cyan" %>
            <span>Definir como personagem principal</span>
          </label>
        </div>

        <div class="flex items-center justify-between pt-4">
          <div class="flex gap-4">
            <%= f.submit "💾 Salvar Alterações", class: "px-6 py-3 bg-gradient-to-r from-neon-cyan to-neon-purple rounded-lg text-white font-semibold cursor-pointer" %>
            <%= link_to "Cancelar", profile_path, class: "px-6 py-3 bg-dark-surface border border-gray-700 rounded-lg text-gray-300" %>
          </div>
          <%= button_to "🗑️ Remover", character_path(@character), method: :delete, data: { confirm: "Tem certeza que deseja remover este personagem?" }, class: "px-4 py-2 bg-dark-surface border border-neon-magenta/30 rounded-lg text-neon-magenta text-sm" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
