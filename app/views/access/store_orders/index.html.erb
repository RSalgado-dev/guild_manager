<div class="min-h-screen bg-dark-bg">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <p class="text-neon-purple/70 font-mono text-xs uppercase">Orders</p>
        <h1 class="text-4xl font-black text-white">Meus pedidos</h1>
        <p class="text-gray-400 mt-2">Acompanhe compras pendentes, entregues, rejeitadas ou canceladas.</p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <%= link_to "Voltar para loja", store_path, class: "inline-flex items-center justify-center border border-neon-cyan/30 bg-dark-card text-neon-cyan font-bold rounded px-4 py-3 hover:border-neon-cyan transition-colors" %>
        <%= link_to "Dashboard", dashboard_path, class: "inline-flex items-center justify-center border border-neon-cyan/30 text-neon-cyan rounded px-4 py-3 hover:border-neon-cyan transition-colors" %>
      </div>
    </div>

    <div class="bg-dark-card border border-neon-purple/20 rounded-lg p-6">
      <% if @orders.any? %>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead class="text-gray-500 text-xs font-mono uppercase border-b border-gray-800">
              <tr>
                <th class="py-3">Pedido</th>
                <th class="py-3">Item</th>
                <th class="py-3">Preço</th>
                <th class="py-3">Status</th>
                <th class="py-3">Criado em</th>
                <th class="py-3 text-right">Ações</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              <% @orders.each do |order| %>
                <tr>
                  <td class="py-3 text-gray-300">#<%= order.id %></td>
                  <td class="py-3 text-white"><%= order.store_item.name %></td>
                  <td class="py-3 text-neon-magenta"><%= order.price_paid %></td>
                  <td class="py-3 text-neon-cyan"><%= order.status %></td>
                  <td class="py-3 text-gray-400"><%= l(order.created_at, format: :short) %></td>
                  <td class="py-3 text-right">
                    <% if order.pending? %>
                      <%= button_to "Cancelar",
                                    cancel_store_order_path(order),
                                    method: :post,
                                    class: "inline-flex items-center justify-center bg-neon-magenta text-white rounded px-3 py-2 text-sm font-bold hover:opacity-90" %>
                    <% else %>
                      <span class="text-gray-500 text-sm">-</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-10">
          <p class="text-gray-400 mb-4">Você ainda não possui pedidos.</p>
          <%= link_to "Abrir loja", store_path, class: "inline-flex items-center justify-center border border-neon-cyan/30 bg-dark-card text-neon-cyan font-bold rounded px-4 py-3 hover:border-neon-cyan transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
