<div class="min-h-screen bg-dark-bg">
  <div class="max-w-4xl mx-auto px-4 py-8 space-y-6">
    <header class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="text-yellow-400 font-mono text-xs">[ ACHIEVEMENT_DETAILS ]</p>
        <h1 class="text-3xl font-black text-white mt-2"><%= @achievement.name %></h1>
        <p class="text-gray-400 mt-2"><%= @achievement.description.presence || "Sem descrição cadastrada." %></p>
      </div>
      <%= link_to achievements_path, class: "px-4 py-2 bg-dark-card border border-gray-700 rounded-lg text-gray-300 font-mono text-sm" do %>
        ← Conquistas
      <% end %>
    </header>

    <section class="bg-dark-card border border-yellow-400/20 rounded-lg p-6 space-y-5">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="p-4 bg-dark-bg border border-gray-800 rounded-lg">
          <p class="text-gray-500 text-xs font-mono uppercase">Tipo</p>
          <p class="text-white mt-2"><%= @achievement.achievement_type.humanize %></p>
        </div>
        <div class="p-4 bg-dark-bg border border-gray-800 rounded-lg">
          <p class="text-gray-500 text-xs font-mono uppercase">Categoria</p>
          <p class="text-white mt-2"><%= @achievement.category.presence || "Geral" %></p>
        </div>
        <div class="p-4 bg-dark-bg border border-neon-green/20 rounded-lg">
          <p class="text-gray-500 text-xs font-mono uppercase">XP</p>
          <p class="text-white mt-2"><%= @achievement.reward_xp %></p>
        </div>
        <div class="p-4 bg-dark-bg border border-yellow-400/20 rounded-lg">
          <p class="text-gray-500 text-xs font-mono uppercase">Moedas</p>
          <p class="text-white mt-2"><%= @achievement.reward_currency %></p>
        </div>
      </div>

      <% if @achievement.grants_customization? %>
        <div class="p-4 bg-dark-bg border border-neon-purple/20 rounded-lg">
          <p class="text-gray-500 text-xs font-mono uppercase">Personalização</p>
          <p class="text-white mt-2">Cor de nome <span style="color:<%= @achievement.reward_profile_name_color %>"><%= @achievement.reward_profile_name_color %></span></p>
        </div>
      <% end %>

      <% if @user_achievement %>
        <div class="p-4 bg-yellow-400/10 border border-yellow-400/30 rounded-lg text-yellow-300 font-mono text-sm">
          Desbloqueada em <%= l(@user_achievement.earned_at, format: :short) %>
        </div>
      <% end %>
    </section>
  </div>
</div>
