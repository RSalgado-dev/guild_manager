<div class="min-h-screen bg-dark-bg relative overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-12 w-80 h-80 bg-neon-cyan opacity-10 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-12 right-12 w-96 h-96 bg-neon-purple opacity-10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1.4s;"></div>
  </div>

  <div class="relative z-10 min-h-screen">
    <header class="border-b border-gray-800 backdrop-blur-sm bg-dark-surface/50">
      <div class="max-w-7xl mx-auto px-4 py-4">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h1 class="text-xl font-black text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-neon-purple">
              GUILD SYSTEM
            </h1>
            <p class="text-neon-cyan/70 font-mono text-xs">[ CREATE_SQUAD ]</p>
          </div>
          <%= link_to squads_path, class: "px-4 py-2 bg-dark-card border border-gray-700 hover:border-neon-cyan/30 text-gray-300 rounded-lg transition-all duration-300 font-mono text-sm" do %>
            ← Voltar
          <% end %>
        </div>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 py-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-8">
        <section class="bg-dark-card border border-neon-cyan/20 rounded-lg p-8">
          <span class="inline-flex items-center px-3 py-1 bg-neon-cyan/20 border border-neon-cyan rounded-full text-neon-cyan text-sm font-mono mb-4">
            Gestão de squads
          </span>
          <h2 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan via-neon-purple to-neon-magenta mb-4">
            Criar Squad
          </h2>
          <p class="text-gray-400 leading-relaxed">
            Defina a identidade básica do squad e associe um líder disponível da guilda. O restante do fluxo de manutenção poderá ser feito na página do próprio squad.
          </p>
        </section>

        <aside class="bg-dark-card border border-neon-purple/20 rounded-lg p-6">
          <h3 class="text-neon-purple font-bold text-lg uppercase mb-4">Regras rápidas</h3>
          <div class="space-y-3 text-sm text-gray-400">
            <div class="p-3 bg-dark-bg rounded-lg border border-neon-purple/20">
              A TAG aceita de 2 a 8 caracteres com letras e números.
            </div>
            <div class="p-3 bg-dark-bg rounded-lg border border-neon-cyan/20">
              O líder selecionado precisa estar sem squad no momento da criação.
            </div>
            <div class="p-3 bg-dark-bg rounded-lg border border-neon-green/20">
              Alterações futuras de perfil passam por revisão antes de serem aprovadas.
            </div>
          </div>
        </aside>
      </div>

      <section class="bg-dark-card border border-neon-purple/30 rounded-lg p-8 mt-8">
        <%= form_with model: @squad, url: squads_path, method: :post, local: true, class: "space-y-6" do |f| %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
              <%= f.label :name, "Nome", class: "block text-sm text-gray-300 mb-2 font-mono uppercase" %>
              <%= f.text_field :name, required: true, class: "w-full px-4 py-3 bg-dark-bg border border-neon-cyan/20 focus:border-neon-cyan rounded-lg text-white" %>
            </div>

            <div>
              <%= f.label :tag, "TAG", class: "block text-sm text-gray-300 mb-2 font-mono uppercase" %>
              <%= f.text_field :tag, required: true, maxlength: 8, class: "w-full px-4 py-3 bg-dark-bg border border-neon-purple/20 focus:border-neon-purple rounded-lg text-white uppercase" %>
            </div>

            <div>
              <%= f.label :leader_id, "Líder do Squad", class: "block text-sm text-gray-300 mb-2 font-mono uppercase" %>
              <%= f.select :leader_id, @leader_candidates.map { |u| ["#{u.discord_username} (ID: #{u.id})", u.id] }, { prompt: "Selecione o líder" }, { required: true, class: "w-full px-4 py-3 bg-dark-bg border border-neon-green/20 focus:border-neon-green rounded-lg text-white" } %>
            </div>

            <div class="md:col-span-2">
              <%= f.label :description, "Descrição", class: "block text-sm text-gray-300 mb-2 font-mono uppercase" %>
              <%= f.text_area :description, rows: 5, class: "w-full px-4 py-3 bg-dark-bg border border-gray-700 focus:border-neon-cyan/40 rounded-lg text-white" %>
            </div>
          </div>

          <div class="flex flex-wrap gap-3 pt-2">
            <%= f.submit "Criar Squad", class: "px-5 py-3 bg-gradient-to-r from-neon-cyan to-neon-blue rounded-lg text-dark-bg font-bold cursor-pointer hover:shadow-neon-cyan transition-all duration-300" %>
            <%= link_to "Cancelar", squads_path, class: "px-5 py-3 bg-dark-bg border border-gray-700 hover:border-neon-magenta/30 rounded-lg text-gray-300 font-mono transition-all duration-300" %>
          </div>
        <% end %>
      </section>
    </main>
  </div>
</div>
