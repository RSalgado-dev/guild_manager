<div class="min-h-screen bg-dark-bg relative overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-8 w-80 h-80 bg-neon-purple opacity-10 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-12 right-8 w-96 h-96 bg-neon-cyan opacity-10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1.3s;"></div>
  </div>

  <div class="relative z-10 min-h-screen">
    <header class="border-b border-gray-800 backdrop-blur-sm bg-dark-surface/50">
      <div class="max-w-7xl mx-auto px-4 py-4">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h1 class="text-xl font-black text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-neon-purple">
              GUILD SYSTEM
            </h1>
            <p class="text-neon-cyan/70 font-mono text-xs">[ SQUAD_REVIEW_QUEUE ]</p>
          </div>
          <%= link_to squads_path, class: "px-4 py-2 bg-dark-card border border-gray-700 hover:border-neon-cyan/30 text-gray-300 rounded-lg transition-all duration-300 font-mono text-sm" do %>
            ← Voltar
          <% end %>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8 space-y-6">
      <section class="bg-dark-card border border-neon-purple/30 rounded-lg p-8">
        <h2 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan via-neon-purple to-neon-magenta mb-3">
          Revisões de Squads
        </h2>
        <p class="text-gray-400 max-w-3xl">
          Aprove ou rejeite alterações de perfil com comparação visual entre o estado atual e o material enviado para revisão, incluindo o novo emblema quando houver.
        </p>
      </section>

      <% if @pending_squads.empty? %>
        <section class="bg-dark-card border border-neon-cyan/20 rounded-lg p-10 text-center">
          <p class="text-gray-300 text-lg">Não há alterações pendentes no momento.</p>
        </section>
      <% end %>

      <% @pending_squads.each do |squad| %>
        <section class="bg-dark-card border border-neon-cyan/20 rounded-lg p-6">
          <div class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
            <div class="flex-1 space-y-6">
              <div>
                <h3 class="text-2xl text-white font-bold">
                  <%= squad.name %> <span class="text-neon-cyan">[<%= squad.tag %>]</span>
                </h3>
                <p class="text-sm text-gray-500 mt-2">
                  Solicitado por <%= squad.leader.discord_username %> em <%= l(squad.profile_change_requested_at, format: :short) %>
                </p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="p-4 bg-dark-bg border border-neon-cyan/20 rounded-lg">
                  <p class="text-xs text-neon-cyan/70 font-mono uppercase">Nome atual</p>
                  <p class="text-white font-bold mt-2"><%= squad.name %></p>
                </div>
                <div class="p-4 bg-dark-bg border border-neon-purple/20 rounded-lg">
                  <p class="text-xs text-neon-cyan/70 font-mono uppercase">Nome proposto</p>
                  <p class="text-white font-bold mt-2"><%= squad.pending_profile_changes["name"].presence || squad.name %></p>
                </div>
                <div class="p-4 bg-dark-bg border border-neon-cyan/20 rounded-lg">
                  <p class="text-xs text-neon-cyan/70 font-mono uppercase">TAG atual</p>
                  <p class="text-white font-bold mt-2"><%= squad.tag %></p>
                </div>
                <div class="p-4 bg-dark-bg border border-neon-purple/20 rounded-lg">
                  <p class="text-xs text-neon-cyan/70 font-mono uppercase">TAG proposta</p>
                  <p class="text-white font-bold mt-2"><%= squad.pending_profile_changes["tag"].presence || squad.tag %></p>
                </div>
                <div class="p-4 bg-dark-bg border border-gray-700 rounded-lg">
                  <p class="text-xs text-neon-cyan/70 font-mono uppercase">Descrição atual</p>
                  <p class="text-gray-300 mt-2 whitespace-pre-line"><%= squad.description.presence || "Sem descrição." %></p>
                </div>
                <div class="p-4 bg-dark-bg border border-neon-purple/20 rounded-lg">
                  <p class="text-xs text-neon-cyan/70 font-mono uppercase">Descrição proposta</p>
                  <p class="text-gray-300 mt-2 whitespace-pre-line"><%= squad.pending_profile_changes["description"].presence || squad.description.presence || "Sem descrição." %></p>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="p-4 bg-dark-bg border border-neon-cyan/20 rounded-lg">
                  <p class="text-xs text-neon-cyan/70 font-mono uppercase mb-3">Emblema atual</p>
                  <% if squad.emblem.attached? %>
                    <div class="w-full max-w-[18rem] aspect-square rounded-2xl border border-neon-cyan/30 bg-dark-surface p-4 flex items-center justify-center">
                      <%= image_tag squad.emblem, class: "w-full h-full object-contain" %>
                    </div>
                  <% else %>
                    <div class="w-full max-w-[18rem] aspect-square rounded-2xl border border-dashed border-gray-700 bg-dark-surface flex items-center justify-center text-gray-500">
                      Sem emblema atual
                    </div>
                  <% end %>
                </div>

                <div class="p-4 bg-dark-bg border border-neon-purple/20 rounded-lg">
                  <p class="text-xs text-neon-cyan/70 font-mono uppercase mb-3">Emblema enviado para revisão</p>
                  <% if squad.emblem_pending.attached? %>
                    <div class="w-full max-w-[18rem] aspect-square rounded-2xl border border-neon-purple/30 bg-dark-surface p-4 flex items-center justify-center">
                      <%= image_tag squad.emblem_pending, class: "w-full h-full object-contain" %>
                    </div>
                  <% else %>
                    <div class="w-full max-w-[18rem] aspect-square rounded-2xl border border-dashed border-gray-700 bg-dark-surface flex items-center justify-center text-gray-500">
                      Nenhuma nova imagem enviada
                    </div>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="xl:w-72 shrink-0 space-y-3">
              <%= button_to "Aprovar", approve_profile_change_squad_path(squad), method: :post, class: "w-full px-4 py-3 bg-neon-green/20 border border-neon-green/40 rounded-lg text-neon-green font-mono" %>
              <%= form_with url: reject_profile_change_squad_path(squad), method: :post, local: true, class: "space-y-3" do |f| %>
                <%= text_field_tag :reason, nil, placeholder: "Motivo da rejeição", required: true, class: "w-full px-4 py-3 text-sm bg-dark-bg border border-gray-700 rounded-lg text-white" %>
                <%= f.submit "Rejeitar", class: "w-full px-4 py-3 bg-neon-magenta/20 border border-neon-magenta/40 rounded-lg text-neon-magenta font-mono" %>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>
    </main>
  </div>
</div>
