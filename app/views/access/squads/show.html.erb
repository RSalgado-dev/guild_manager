<div class="min-h-screen bg-dark-bg">
  <div class="min-h-screen">
    <header class="border-b border-gray-800 backdrop-blur-sm bg-dark-surface/50">
      <div class="max-w-7xl mx-auto px-4 py-4">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="flex items-center gap-4">
            <%= link_to squads_path, class: "flex items-center gap-3 hover:opacity-80 transition-opacity" do %>
              <span class="text-3xl">🛡️</span>
              <div>
                <h1 class="text-xl font-black text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-neon-purple">
                  Squad
                </h1>
              </div>
            <% end %>
          </div>
          <%= link_to squads_path, class: "px-4 py-2 bg-dark-card border border-gray-700 hover:border-neon-cyan/30 text-gray-300 rounded-lg transition-all duration-300 font-mono text-sm" do %>
            ← Voltar aos Squads
          <% end %>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8 space-y-6">
      <!-- Informações Principais -->
      <section class="bg-dark-card border border-neon-purple/30 rounded-lg p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
          
          <!-- Emblema Lateral Direita -->
          <div class="md:col-span-1 flex items-start justify-center">
            <% if @squad.emblem.attached? %>
              <div class="w-full max-w-xs aspect-square rounded-xl border-2 border-neon-cyan/40 shadow-lg shadow-neon-cyan/20 bg-white p-3 flex items-center justify-center">
                <%= image_tag @squad.emblem, class: "w-full h-full object-contain" %>
              </div>
            <% else %>
              <div class="w-full max-w-xs aspect-square rounded-xl border-2 border-neon-cyan/30 bg-dark-card flex items-center justify-center text-5xl text-gray-500">
                🛡️
              </div>
            <% end %>
          </div>

          <!-- Bloco de Informações Esquerda -->
          <div class="md:col-span-2 space-y-4">
            <div>
              <h2 class="text-2xl md:text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan via-neon-purple to-neon-magenta">
                <%= @squad.name %> [<%= @squad.tag %>]
              </h2>
              <p class="text-gray-400 text-base leading-relaxed mt-2">
                <%= @squad.description.presence || "Sem descrição cadastrada." %>
              </p>
            </div>

            <div class="flex flex-wrap items-center gap-2">
              <span class="px-3 py-1 bg-neon-purple/20 border border-neon-purple rounded-full text-neon-purple text-xs font-mono">
                Squad Ativo
              </span>
              <span class="px-3 py-1 bg-neon-cyan/20 border border-neon-cyan rounded-full text-neon-cyan text-xs font-mono">
                <%= @members.count %> <%= @members.count == 1 ? 'membro' : 'membros' %>
              </span>
              <% if @squad.profile_change_pending? %>
                <span class="px-3 py-1 bg-yellow-500/20 border border-yellow-400 rounded-full text-yellow-300 text-xs font-mono">
                  Alteração pendente
                </span>
              <% end %>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              <div class="bg-dark-bg border border-neon-cyan/20 rounded-lg p-3">
                <p class="text-xs text-neon-cyan/70 font-mono uppercase">Líder</p>
                <p class="text-white font-semibold text-sm mt-1 break-words"><%= @squad.leader.discord_username %></p>
              </div>
              <div class="bg-dark-bg border border-neon-green/20 rounded-lg p-3">
                <p class="text-xs text-neon-cyan/70 font-mono uppercase">Seu papel</p>
                <p class="text-white font-semibold text-sm mt-1"><%= @squad.leader_id == current_user.id ? "Líder" : "Membro" %></p>
              </div>
              <div class="bg-dark-bg border border-neon-purple/20 rounded-lg p-3">
                <p class="text-xs text-neon-cyan/70 font-mono uppercase">Status</p>
                <p class="text-white font-semibold text-sm mt-1"><%= @squad.profile_change_pending? ? "Em revisão" : "Ativo" %></p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Membros e Ações -->
      <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <!-- Lista de Membros -->
        <section class="bg-dark-card border border-neon-cyan/20 rounded-lg p-5">
          <h3 class="text-neon-cyan font-bold text-lg uppercase mb-4 flex items-center gap-2">
            <span>👥</span> Membros (<%= @members.count %>)
          </h3>
          <div class="space-y-2">
            <% @members.each do |member| %>
              <div class="p-3 bg-dark-bg border border-neon-cyan/10 rounded-lg flex items-center justify-between gap-3 hover:border-neon-cyan/30 transition-colors">
                <div class="flex-1 min-w-0">
                  <p class="text-white font-semibold truncate"><%= member.display_name_with_squad_tag %></p>
                  <p class="text-xs text-gray-500">ID: <%= member.id %></p>
                </div>
                <% if member.id == @squad.leader_id %>
                  <span class="px-2 py-1 bg-neon-green/20 border border-neon-green rounded text-neon-green text-xs font-mono uppercase flex-shrink-0">Líder</span>
                <% end %>
              </div>
            <% end %>
          </div>
        </section>

        <!-- Gerenciamento (apenas para líder) -->
        <% if @squad.leader_id == current_user.id %>
          <section class="bg-dark-card border border-neon-purple/30 rounded-lg p-5">
            <h3 class="text-neon-purple font-bold text-lg uppercase mb-4 flex items-center gap-2">
              <span>⚙️</span> Alteração de Perfil
            </h3>

            <% if @squad.profile_change_pending? %>
              <div class="space-y-4">
                <div class="p-3 bg-yellow-500/10 border border-yellow-400/30 rounded-lg">
                  <p class="text-yellow-300 font-semibold text-sm">⏳ Alteração em revisão</p>
                  <p class="text-gray-400 text-xs mt-1">Aguardando aprovação dos administradores.</p>
                </div>

                <div class="space-y-3">
                  <div class="p-3 bg-dark-bg border border-neon-cyan/20 rounded-lg">
                    <p class="text-xs text-neon-cyan/70 font-mono uppercase">Nome proposto</p>
                    <p class="text-white font-semibold text-sm mt-1"><%= @squad.pending_profile_changes["name"].presence || @squad.name %></p>
                  </div>
                  <div class="p-3 bg-dark-bg border border-neon-purple/20 rounded-lg">
                    <p class="text-xs text-neon-cyan/70 font-mono uppercase">TAG proposta</p>
                    <p class="text-white font-semibold text-sm mt-1"><%= @squad.pending_profile_changes["tag"].presence || @squad.tag %></p>
                  </div>
                  <div class="p-3 bg-dark-bg border border-gray-700 rounded-lg">
                    <p class="text-xs text-neon-cyan/70 font-mono uppercase">Descrição proposta</p>
                    <p class="text-gray-300 text-sm mt-1 whitespace-pre-line"><%= @squad.pending_profile_changes["description"].presence || @squad.description.presence || "Sem descrição." %></p>
                  </div>

                  <% if @squad.emblem_pending.attached? %>
                    <div class="p-3 bg-dark-bg border border-neon-purple/20 rounded-lg">
                      <p class="text-xs text-neon-cyan/70 font-mono uppercase mb-2">Novo emblema proposto</p>
                      <div class="w-32 h-32 rounded-lg border border-neon-purple/30 bg-dark-surface p-2 flex items-center justify-center">
                        <%= image_tag @squad.emblem_pending, class: "w-full h-full object-contain" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% elsif !@squad.can_request_profile_change? %>
              <div class="p-3 bg-yellow-500/10 border border-yellow-400/30 rounded-lg">
                <p class="text-yellow-300 font-semibold text-sm">Intervalo ativo</p>
                <p class="text-gray-400 text-xs mt-1">
                  Disponível em <%= l(@squad.next_profile_change_available_at, format: :short) %>
                </p>
              </div>
            <% else %>
              <%= form_with model: @squad, url: request_profile_change_squad_path(@squad), method: :patch, local: true, class: "space-y-4" do |f| %>
                <div class="space-y-3">
                  <div>
                    <%= f.label :name, "Nome", class: "block text-xs text-gray-300 mb-1 font-mono uppercase" %>
                    <%= f.text_field :name, value: @squad.name, class: "w-full px-3 py-2 bg-dark-bg border border-neon-cyan/20 focus:border-neon-cyan rounded-lg text-white text-sm" %>
                  </div>
                  <div>
                    <%= f.label :tag, "TAG", class: "block text-xs text-gray-300 mb-1 font-mono uppercase" %>
                    <%= f.text_field :tag, value: @squad.tag, maxlength: 8, class: "w-full px-3 py-2 bg-dark-bg border border-neon-purple/20 focus:border-neon-purple rounded-lg text-white text-sm uppercase" %>
                  </div>
                  <div>
                    <%= f.label :description, "Descrição", class: "block text-xs text-gray-300 mb-1 font-mono uppercase" %>
                    <%= f.text_area :description, value: @squad.description, rows: 3, class: "w-full px-3 py-2 bg-dark-bg border border-gray-700 focus:border-neon-cyan/30 rounded-lg text-white text-sm" %>
                  </div>
                  <div>
                    <%= f.label :emblem_pending, "Nova Imagem", class: "block text-xs text-gray-300 mb-1 font-mono uppercase" %>
                    <%= f.file_field :emblem_pending, accept: "image/png,image/jpeg,image/webp", class: "w-full px-3 py-2 bg-dark-bg border border-gray-700 rounded-lg text-xs text-gray-300 file:mr-2 file:border-0 file:bg-neon-purple/20 file:px-2 file:py-1 file:text-neon-purple file:rounded file:text-xs" %>
                  </div>

                  <% if @squad.emblem.attached? %>
                    <div class="p-3 bg-dark-bg border border-neon-cyan/20 rounded-lg">
                      <p class="text-xs text-neon-cyan/70 font-mono uppercase mb-2">Emblema atual</p>
                      <div class="w-24 h-24 rounded-lg border border-neon-cyan/30 bg-dark-surface p-2 flex items-center justify-center">
                        <%= image_tag @squad.emblem, class: "w-full h-full object-contain" %>
                      </div>
                    </div>
                  <% end %>
                </div>

                <%= f.submit "Enviar para revisão", class: "w-full px-4 py-2 bg-gradient-to-r from-neon-purple to-neon-magenta rounded-lg text-white font-bold text-sm cursor-pointer hover:shadow-lg hover:shadow-neon-purple/50 transition-all duration-300" %>
              <% end %>
            <% end %>
          </section>
        <% end %>
      </div>

      <!-- Convites (apenas para líder) -->
      <% if @squad.leader_id == current_user.id %>
        <section class="bg-dark-card border border-neon-green/30 rounded-lg p-5">
          <h3 class="text-neon-green font-bold text-lg uppercase mb-4 flex items-center gap-2">
            <span>✉️</span> Convidar Membro
          </h3>
          
          <%= form_with url: create_invitation_squad_path(@squad), method: :post, local: true, class: "space-y-4" do |f| %>
            <div class="flex flex-col sm:flex-row gap-3">
              <div class="flex-1">
                <select name="invitee_id" required class="w-full px-3 py-2 bg-dark-bg border border-neon-green/20 focus:border-neon-green rounded-lg text-white text-sm">
                  <option value="">Selecione um usuário sem squad</option>
                  <% @eligible_members_for_invite.each do |user| %>
                    <option value="<%= user.id %>"><%= user.discord_username %></option>
                  <% end %>
                </select>
              </div>
              <%= f.submit "Enviar convite", class: "px-4 py-2 bg-neon-green/20 border border-neon-green/40 rounded-lg text-neon-green font-mono text-sm cursor-pointer hover:bg-neon-green/30 transition-colors" %>
            </div>
          <% end %>

          <% if @pending_invitations&.any? %>
            <div class="mt-4 pt-4 border-t border-gray-700">
              <h4 class="text-xs text-gray-400 mb-2 font-mono uppercase">Convites pendentes (<%= @pending_invitations.count %>)</h4>
              <div class="space-y-2">
                <% @pending_invitations.each do |invitation| %>
                  <div class="p-2 bg-dark-bg border border-neon-green/20 rounded-lg text-xs">
                    <span class="font-semibold text-white"><%= invitation.invitee.discord_username %></span>
                    <span class="text-gray-500"> • expira <%= l(invitation.expires_at, format: :short) %></span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>
    </main>
  </div>
</div>
