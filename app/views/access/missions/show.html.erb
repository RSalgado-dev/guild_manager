<div class="min-h-screen bg-dark-bg">
  <div class="max-w-5xl mx-auto px-4 py-8 space-y-6">
    <header class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <h1 class="text-3xl font-black text-white"><%= @mission.name %></h1>
        <p class="text-gray-400 mt-2"><%= @mission.description.presence || "Sem descrição cadastrada." %></p>
      </div>
      <%= link_to missions_path, class: "px-4 py-2 bg-dark-card border border-gray-700 rounded-lg text-gray-300 font-mono text-sm" do %>
        ← Missões
      <% end %>
    </header>

    <section class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-dark-card border border-neon-cyan/20 rounded-lg p-4">
        <p class="text-gray-500 text-xs font-mono uppercase">Tipo</p>
        <p class="text-white mt-2"><%= enum_label(@mission.mission_type) %></p>
      </div>
      <div class="bg-dark-card border border-neon-purple/20 rounded-lg p-4">
        <p class="text-gray-500 text-xs font-mono uppercase">Período</p>
        <p class="text-white mt-2"><%= @period_reference %></p>
      </div>
      <div class="bg-dark-card border border-neon-green/20 rounded-lg p-4">
        <p class="text-gray-500 text-xs font-mono uppercase">XP</p>
        <p class="text-white mt-2"><%= @mission.fixed? ? @mission.reward_xp : "#{@mission.reward_xp_per_unit}/un" %></p>
      </div>
      <div class="bg-dark-card border border-yellow-400/20 rounded-lg p-4">
        <p class="text-gray-500 text-xs font-mono uppercase">Moedas</p>
        <p class="text-white mt-2"><%= @mission.fixed? ? @mission.reward_currency : "#{@mission.reward_currency_per_unit}/un" %></p>
      </div>
    </section>

    <% if @mission.manual? %>
      <section class="bg-dark-card border border-neon-purple/20 rounded-lg p-6">
        <div class="flex items-center justify-between gap-4 mb-5">
          <div>
            <h2 class="text-xl font-bold text-white">Enviar submissão</h2>
            <p class="text-gray-400 text-sm mt-1">Envios neste período: <%= @period_submissions.count %>/<%= @mission.max_submissions_per_period %></p>
          </div>
        </div>

        <% if @mission.accepts_submission_from?(current_user, @period_reference) %>
          <%= form_with model: @submission, url: submit_mission_path(@mission), method: :post, local: true, multipart: true, class: "space-y-4" do |f| %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <%= f.label :quantity, "Quantidade", class: "block text-sm text-gray-300 mb-2" %>
                <%= f.number_field :quantity, min: 1, class: "w-full px-4 py-3 bg-dark-bg border border-neon-purple/20 rounded-lg text-white" %>
              </div>
              <div>
                <%= f.label :proof, "Comprovante", class: "block text-sm text-gray-300 mb-2" %>
                <%= f.file_field :proof, class: "w-full px-4 py-3 bg-dark-bg border border-gray-700 rounded-lg text-white" %>
              </div>
            </div>
            <div>
              <%= f.label :notes, "Notas", class: "block text-sm text-gray-300 mb-2" %>
              <%= f.text_area :notes, rows: 4, class: "w-full px-4 py-3 bg-dark-bg border border-gray-700 rounded-lg text-white" %>
            </div>
            <%= f.submit "Enviar para revisão", class: "px-5 py-3 bg-gradient-to-r from-neon-purple to-neon-magenta rounded-lg text-white font-bold cursor-pointer" %>
          <% end %>
        <% else %>
          <div class="p-4 bg-dark-bg border border-gray-700 rounded-lg">
            <p class="text-gray-300">Limite de submissões atingido para este período.</p>
          </div>
        <% end %>
      </section>
    <% end %>

    <section class="space-y-4">
      <h2 class="text-xl font-bold text-white">Submissões deste período</h2>
      <% if @period_submissions.any? %>
        <div class="space-y-3">
          <% @period_submissions.each do |submission| %>
            <div class="bg-dark-card border border-gray-800 rounded-lg p-4">
              <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                  <p class="text-white font-semibold">Envio <%= submission.period_sequence %></p>
                  <p class="text-gray-500 text-sm">Quantidade <%= submission.quantity %> • <%= l(submission.created_at, format: :short) %></p>
                  <% if submission.review_notes.present? %>
                    <p class="text-gray-400 text-sm mt-2"><%= submission.review_notes %></p>
                  <% end %>
                </div>
                <div class="flex gap-2 text-xs font-mono">
                  <span class="px-2 py-1 bg-dark-bg border border-gray-700 rounded text-gray-300"><%= enum_label(submission.status) %></span>
                  <span class="px-2 py-1 bg-neon-green/10 border border-neon-green/30 rounded text-neon-green"><%= submission.reward_xp_awarded %> XP</span>
                  <span class="px-2 py-1 bg-yellow-400/10 border border-yellow-400/30 rounded text-yellow-300"><%= submission.reward_currency_awarded %> moedas</span>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-dark-card border border-dashed border-gray-700 rounded-lg p-8 text-center">
          <p class="text-gray-400">Nenhuma submissão enviada neste período.</p>
        </div>
      <% end %>
    </section>
  </div>
</div>
