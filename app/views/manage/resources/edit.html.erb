<main class="min-h-screen bg-dark-bg text-gray-100">
  <section class="max-w-4xl mx-auto px-4 py-8">
    <%= link_to "← #{manage_record_label(@resource)}", manage_resource_path(@resource_key, @resource), class: "text-neon-cyan text-sm font-mono" %>
    <h1 class="text-3xl font-black text-white mt-2 mb-6">Editar registro</h1>
    <%= render "form" %>
  </section>
</main>
