<main class="min-h-screen bg-dark-bg text-gray-100">
  <section class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-6">
      <div>
        <%= link_to "← #{@config[:label]}", manage_resources_path(@resource_key), class: "text-neon-cyan text-sm font-mono" %>
        <h1 class="text-3xl font-black text-white mt-2"><%= manage_record_label(@resource) %></h1>
      </div>

      <div class="flex flex-wrap gap-2">
        <% unless @config[:readonly] %>
          <%= link_to "Editar", manage_edit_resource_path(@resource_key, @resource), class: "rounded border border-neon-cyan/50 bg-neon-cyan/10 px-4 py-2 text-neon-cyan font-mono text-sm hover:border-neon-cyan" %>
          <%= button_to "Remover", manage_resource_path(@resource_key, @resource), method: :delete, class: "rounded border border-red-500/50 bg-red-500/10 px-4 py-2 text-red-300 font-mono text-sm hover:border-red-400", form: { data: { turbo_confirm: "Remover este registro?" } } unless @config[:singleton] %>
        <% end %>
      </div>
    </div>

    <% if @config[:actions].present? %>
      <div class="border border-gray-800 bg-dark-card rounded p-4 mb-6">
        <div class="flex flex-wrap gap-2">
          <% @config[:actions].each do |action| %>
            <%= button_to manage_action_label(action),
                          manage_resource_action_path(@resource_key, @resource, action),
                          method: :post,
                          params: { notes: params[:notes], reason: params[:reason] },
                          class: "rounded border border-neon-purple/50 bg-neon-purple/10 px-3 py-2 text-neon-purple font-mono text-xs hover:border-neon-purple" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="border border-gray-800 bg-dark-card rounded divide-y divide-gray-800">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 p-4">
        <p class="text-gray-400 font-mono text-sm">ID</p>
        <div class="md:col-span-2 text-white">#<%= @resource.id %></div>
      </div>
      <% @config[:fields].each do |field| %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 p-4">
          <p class="text-gray-400 font-mono text-sm"><%= field[:label] %></p>
          <div class="md:col-span-2 text-white"><%= manage_field_value(@resource, field) %></div>
        </div>
      <% end %>
    </div>
  </section>
</main>
