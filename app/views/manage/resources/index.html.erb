<%= render "shared/member_navigation" %>

<main class="min-h-screen bg-dark-bg text-gray-100">
  <section class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-6">
      <div>
        <%= link_to "← Gestão", manage_root_path, class: "text-neon-cyan text-sm font-mono" %>
        <h1 class="text-3xl font-black text-white mt-2"><%= @config[:label] %></h1>
      </div>

      <% unless @config[:readonly] || @config[:no_create] || @config[:singleton] %>
        <%= link_to "Novo registro", manage_new_resource_path(@resource_key), class: "inline-flex items-center justify-center rounded border border-neon-green/50 bg-neon-green/10 px-4 py-2 text-neon-green font-mono text-sm hover:border-neon-green" %>
      <% end %>
    </div>

    <div class="overflow-x-auto border border-gray-800 rounded bg-dark-card">
      <table class="min-w-full divide-y divide-gray-800">
        <thead class="bg-dark-surface">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-mono text-gray-400 uppercase">ID</th>
            <% @config[:fields].reject { |field| field[:type].in?([ :text, :json, :multiselect ]) }.first(5).each do |field| %>
              <th class="px-4 py-3 text-left text-xs font-mono text-gray-400 uppercase"><%= field[:label] %></th>
            <% end %>
            <th class="px-4 py-3 text-right text-xs font-mono text-gray-400 uppercase">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @resources.each do |resource| %>
            <tr>
              <td class="px-4 py-3 text-sm text-gray-300">#<%= resource.id %></td>
              <% @config[:fields].reject { |field| field[:type].in?([ :text, :json, :multiselect ]) }.first(5).each do |field| %>
                <td class="px-4 py-3 text-sm text-gray-300"><%= manage_field_value(resource, field) %></td>
              <% end %>
              <td class="px-4 py-3 text-right text-sm">
                <%= link_to "Abrir", manage_resource_path(@resource_key, resource), class: "text-neon-cyan hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</main>
